---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProjectItem from '../components/ProjectItem.astro';

const EMAIL = 'lesterong776@gmail.com';

const projects = (await getEntry('projects', 'projects'))?.data || [];

let NUM_NON_FAVOURITE_TO_SHOW = 2;
let visibleNonFavouriteCount = 0;
const workProjects = projects.map((project) => {
  if (project.isFavourite) {
    return { ...project, initiallyHidden: false };
  }

  visibleNonFavouriteCount += 1;
  return {
    ...project,
    initiallyHidden: visibleNonFavouriteCount > NUM_NON_FAVOURITE_TO_SHOW,
  };
});
const hiddenProjectCount = workProjects.filter(
  (project) => project.initiallyHidden,
).length;

const sectionClass = 'my-8';
const headingClass = 'mb-1 font-light font-serif italic';
const bodyClass = 'text-muted-foreground leading-relaxed';
---

<Layout>
  <div
    class="pointer-events-none fixed inset-0 z-0 overflow-hidden"
    aria-hidden="true"
  >
    <div data-scroll-orb class="absolute top-0 left-1/2 will-change-transform">
      <div
        class="size-120 -translate-x-1/2 translate-y-[8%] rounded-full bg-[#ff66ff]/18 opacity-70 blur-3xl dark:bg-[#ff66ff]/10"
      >
      </div>
    </div>
  </div>

  <main class="relative z-10 mx-auto max-w-152 px-4 py-8 sm:px-6 sm:py-10">
    <header class="mb-8 sm:mb-12">
      <h1 class="text-base font-semibold">lesterong</h1>
      <p class="text-muted-foreground -mt-0.5">/ design + engineering</p>
    </header>

    <section class={sectionClass} aria-label="Introduction">
      <p class={bodyClass}>
        Hey! I'm Lester. I build interfaces for the web and iOS, with an
        interest in front-end engineering, animation, and human-computer
        interaction.
      </p>
      <p class={`${bodyClass} mt-3`}>
        I like software that feels clear, polished, and easy to use. Most of my
        work sits somewhere between engineering and design: shaping the product,
        refining the details, and shipping the interface.
      </p>
    </section>

    <section class={sectionClass}>
      <h2 class={headingClass}>present</h2>
      <p class={bodyClass}>
        I currently work as an iOS engineer at a large-scale e-commerce company.
        Outside of work, I'm exploring creative tools, spatial interfaces, and
        practical ways AI can support better products.
      </p>
    </section>

    <section class={sectionClass}>
      <h2 class={headingClass}>past</h2>
      <p class={bodyClass}>
        I started learning web development in 2020 through
        <a href="https://www.theodinproject.com/" target="_blank" rel="noopener"
          >The Odin Project</a
        >. Since then, I've worked on projects across digital twins,
        architecture, education technology and games. In 2025, I graduated from
        the National University of Singapore with a B.Comp in Computer Science.
      </p>
    </section>

    <section class={sectionClass}>
      <div class="mb-2 flex items-baseline justify-between gap-4">
        <h2 class={headingClass}>work</h2>
        <p class="text-muted-foreground text-sm leading-relaxed">
          <span aria-hidden="true">✧</span> favourites
        </p>
      </div>
      <div class="relative pb-14" data-work-list>
        <div class="work-table-mask" data-work-mask>
          <table class="block w-full border-collapse sm:table">
            <tbody class="block sm:table-row-group">
              {workProjects.map((project) => <ProjectItem {...project} />)}
            </tbody>
          </table>
        </div>
        {
          hiddenProjectCount > 0 && (
            <button
              type="button"
              data-work-toggle
              data-collapsed-label={`show ${hiddenProjectCount} more`}
              data-expanded-label="show fewer"
              aria-expanded="false"
              class="text-muted-foreground hover:text-foreground absolute bottom-0 left-1/2 -translate-x-1/2 text-sm underline underline-offset-4 transition-colors"
            >
              show {hiddenProjectCount} more
            </button>
          )
        }
      </div>
    </section>

    <section class={sectionClass}>
      <h2 class={headingClass}>social</h2>
      <p class={bodyClass}>
        You can find me on
        <a href="https://github.com/lesterong" target="_blank" rel="noopener"
          >GitHub</a
        >, connect on
        <a
          href="https://linkedin.com/in/lesterongpc"
          target="_blank"
          rel="noopener">LinkedIn</a
        >, or <a href={`mailto:${EMAIL}`}>email</a> me.
      </p>
    </section>

    <footer class="mt-8 sm:mt-12">
      <p class="text-muted-foreground text-sm leading-relaxed">
        lesterong.com / 2019–{new Date().getFullYear()}
      </p>
    </footer>
  </main>

  <script is:inline>
    const orb = document.querySelector('[data-scroll-orb]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const workList = document.querySelector('[data-work-list]');
    const workMask = document.querySelector('[data-work-mask]');
    const workToggle = document.querySelector('[data-work-toggle]');
    const extraWorkRows = document.querySelectorAll('[data-work-extra]');

    const setWorkExpanded = (isExpanded) => {
      extraWorkRows.forEach((row) => {
        row.hidden = !isExpanded;
      });

      if (workMask) {
        workMask.classList.toggle('work-table-mask', !isExpanded);
      }

      if (workList) {
        workList.classList.toggle('pb-14', !isExpanded);
        workList.style.paddingBottom = isExpanded ? '3.5rem' : '';
      }

      if (workToggle) {
        workToggle.setAttribute('aria-expanded', String(isExpanded));
        workToggle.textContent = isExpanded
          ? workToggle.dataset.expandedLabel
          : workToggle.dataset.collapsedLabel;
      }
    };

    if (workToggle && extraWorkRows.length > 0) {
      workToggle.addEventListener('click', () => {
        const isExpanded = workToggle.getAttribute('aria-expanded') === 'true';
        setWorkExpanded(!isExpanded);
      });
    }

    if (orb && !reducedMotion.matches) {
      let ticking = false;

      const updateOrb = () => {
        const progress = window.scrollY;
        const y = progress * 0.08;
        const x = Math.sin(progress * 0.002) * 18;

        orb.style.transform = `translate3d(${x}px, ${y}px, 0)`;
        ticking = false;
      };

      const requestUpdate = () => {
        if (!ticking) {
          window.requestAnimationFrame(updateOrb);
          ticking = true;
        }
      };

      updateOrb();
      window.addEventListener('scroll', requestUpdate, { passive: true });
    }
  </script>
</Layout>
