---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProjectItem from '../components/ProjectItem.astro';

const EMAIL = 'lesterong776@gmail.com';

const projects = (await getEntry('projects', 'projects'))?.data || [];

const sectionClass = 'my-8';
const headingClass = 'mb-1 font-light font-serif italic';
const bodyClass = 'text-muted-foreground leading-relaxed';
---

<Layout>
  <div
    class="pointer-events-none fixed inset-0 z-0 overflow-hidden"
    aria-hidden="true"
  >
    <div data-scroll-orb class="absolute top-0 left-1/2 will-change-transform">
      <div
        class="size-120 -translate-x-1/2 translate-y-[8%] rounded-full bg-[#ff66ff]/18 opacity-70 blur-3xl dark:bg-[#ff66ff]/10"
      >
      </div>
    </div>
  </div>

  <main class="relative z-10 mx-auto max-w-152 px-4 py-16 sm:px-6 sm:py-10">
    <header class="mb-16 sm:mb-12">
      <h1 class="text-base font-semibold">lesterong</h1>
      <p class="text-muted-foreground -mt-0.5">/ design + engineering</p>
    </header>

    <section class={sectionClass} aria-label="Introduction">
      <p class={bodyClass}>
        Hey! I'm Lester. I build interfaces for the web and iOS, with an
        interest in front-end engineering, animation, and human-computer
        interaction.
      </p>
      <p class={`${bodyClass} mt-3`}>
        I like software that feels clear, polished, and easy to use. Most of my
        work sits somewhere between engineering and design: shaping the product,
        refining the details, and shipping the interface.
      </p>
    </section>

    <section class={sectionClass}>
      <h2 class={headingClass}>present</h2>
      <p class={bodyClass}>
        I currently work as an iOS engineer at a large-scale e-commerce company.
        Outside of work, I'm exploring creative tools, spatial interfaces, and
        practical ways AI can support better products.
      </p>
    </section>

    <section class={sectionClass}>
      <h2 class={headingClass}>past</h2>
      <p class={bodyClass}>
        I started learning web development in 2020 through
        <a href="https://www.theodinproject.com/" target="_blank" rel="noopener"
          >The Odin Project</a
        >. Since then, I've worked on projects across digital twins,
        architecture, education technology and games. In 2025, I graduated from
        the National University of Singapore with a B.Comp in Computer Science.
      </p>
    </section>

    <section class={sectionClass}>
      <div class="mb-2 flex items-baseline justify-between gap-4">
        <h2 class={headingClass}>work</h2>
        <p class="text-muted-foreground text-sm leading-relaxed">
          <span aria-hidden="true">✧</span> favourites
        </p>
      </div>
      <table class="block w-full border-collapse sm:table">
        <tbody class="block sm:table-row-group">
          {projects.map((project) => <ProjectItem {...project} />)}
        </tbody>
      </table>
    </section>

    <section class={sectionClass}>
      <h2 class={headingClass}>social</h2>
      <p class={bodyClass}>
        You can find me on
        <a href="https://github.com/lesterong" target="_blank" rel="noopener"
          >GitHub</a
        >, connect on
        <a
          href="https://linkedin.com/in/lesterongpc"
          target="_blank"
          rel="noopener">LinkedIn</a
        >, or <a href={`mailto:${EMAIL}`}>email</a> me.
      </p>
    </section>

    <footer class="mt-16">
      <p class="text-muted-foreground text-sm leading-relaxed">
        lesterong.com / 2019–{new Date().getFullYear()}
      </p>
    </footer>
  </main>

  <script is:inline>
    const orb = document.querySelector('[data-scroll-orb]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    if (orb && !reducedMotion.matches) {
      let ticking = false;

      const updateOrb = () => {
        const progress = window.scrollY;
        const y = progress * 0.08;
        const x = Math.sin(progress * 0.002) * 18;

        orb.style.transform = `translate3d(${x}px, ${y}px, 0)`;
        ticking = false;
      };

      const requestUpdate = () => {
        if (!ticking) {
          window.requestAnimationFrame(updateOrb);
          ticking = true;
        }
      };

      updateOrb();
      window.addEventListener('scroll', requestUpdate, { passive: true });
    }
  </script>
</Layout>
