---
import { getEntry } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import ProjectItem from '../components/ProjectItem.astro';

const EMAIL = 'lesterong776@gmail.com';

const projects = (await getEntry('projects', 'projects'))?.data || [];

let NUM_NON_FAVOURITE_TO_SHOW = 2;
let visibleNonFavouriteCount = 0;
const workProjects = projects.map((project) => {
  if (project.isFavourite) {
    return { ...project, initiallyHidden: false };
  }

  visibleNonFavouriteCount += 1;
  return {
    ...project,
    initiallyHidden: visibleNonFavouriteCount > NUM_NON_FAVOURITE_TO_SHOW,
  };
});
const hiddenProjectCount = workProjects.filter(
  (project) => project.initiallyHidden,
).length;

const revealClass =
  'animate-[reveal_420ms_ease-out_both] [animation-delay:var(--reveal-delay,0ms)] motion-reduce:animate-none';
const sectionClass = 'my-8';
const headingClass = 'mb-1 font-light font-serif italic';
const bodyClass = 'text-muted-foreground leading-relaxed';
---

<Layout>
  <div
    class="pointer-events-none fixed inset-0 z-0 overflow-hidden"
    aria-hidden="true"
  >
    <div data-scroll-orb class="absolute top-0 left-1/2 will-change-transform">
      <div class="-translate-x-1/2 translate-y-[8%]">
        <div
          class="size-120 origin-center animate-[orb-entry_900ms_cubic-bezier(0.22,1,0.36,1)_both] rounded-full bg-[#ff66ff]/18 opacity-70 blur-3xl will-change-transform motion-reduce:animate-none dark:bg-[#ff66ff]/10"
        >
        </div>
      </div>
    </div>
  </div>

  <main class="relative z-10 mx-auto max-w-152 px-4 py-8 sm:px-6 sm:py-10">
    <header class:list={[revealClass, 'mb-8']} style="--reveal-delay: 0ms">
      <h1 class="text-lg font-semibold">lesterong</h1>
    </header>

    <section
      class:list={[revealClass, sectionClass, '']}
      style="--reveal-delay: 60ms"
      aria-label="Introduction"
    >
      <p class={bodyClass}>
        Hey! I'm Lester. I build interfaces for the web and iOS, with an
        interest in front-end engineering, animation, and human-computer
        interaction.
      </p>
      <p class:list={[bodyClass, 'mt-3']}>
        I like software that feels clear, polished, and easy to use. Most of my
        work sits somewhere between engineering and design: shaping the product,
        refining the details, and shipping the interface.
      </p>
    </section>

    <section
      class:list={[revealClass, sectionClass]}
      style="--reveal-delay: 120ms"
    >
      <h2 class={headingClass}>present</h2>
      <p class={bodyClass}>
        I currently work as an iOS engineer at a large-scale e-commerce company.
        Outside of work, I'm exploring creative tools, spatial interfaces, and
        practical ways AI can support better products.
      </p>
    </section>

    <section
      class:list={[revealClass, sectionClass]}
      style="--reveal-delay: 180ms"
    >
      <h2 class={headingClass}>past</h2>
      <p class={bodyClass}>
        I started learning web development in 2020 through
        <a href="https://www.theodinproject.com/" target="_blank" rel="noopener"
          >The Odin Project</a
        >. Since then, I've worked on projects across digital twins,
        architecture, education technology and games. In 2025, I graduated from
        the National University of Singapore with a B.Comp in Computer Science.
      </p>
    </section>

    <section
      class:list={[revealClass, sectionClass]}
      style="--reveal-delay: 240ms"
    >
      <div class="mb-2 flex items-baseline justify-between gap-4">
        <h2 class={headingClass}>work</h2>
        <p class="text-muted-foreground text-sm leading-relaxed">
          <span aria-hidden="true">✧</span> favourites
        </p>
      </div>
      <div class="relative pb-14" data-work-list>
        <div
          class="work-table-mask overflow-hidden transition-[height] duration-300 ease-out"
          data-work-mask
        >
          <table class="block w-full border-collapse sm:table">
            <tbody class="block sm:table-row-group">
              {workProjects.map((project) => <ProjectItem {...project} />)}
            </tbody>
          </table>
        </div>
        {
          hiddenProjectCount > 0 && (
            <button
              type="button"
              data-work-toggle
              data-collapsed-label={`show ${hiddenProjectCount} more`}
              data-expanded-label="show fewer"
              aria-expanded="false"
              class="text-muted-foreground hover:text-foreground absolute bottom-0 left-1/2 -translate-x-1/2 text-sm underline underline-offset-4 transition-colors"
            >
              show {hiddenProjectCount} more
            </button>
          )
        }
      </div>
    </section>

    <section
      class:list={[revealClass, sectionClass]}
      style="--reveal-delay: 300ms"
    >
      <h2 class={headingClass}>social</h2>
      <p class={bodyClass}>
        You can find me on
        <a href="https://github.com/lesterong" target="_blank" rel="noopener"
          >GitHub</a
        >, connect on
        <a
          href="https://linkedin.com/in/lesterongpc"
          target="_blank"
          rel="noopener">LinkedIn</a
        >, or <a href={`mailto:${EMAIL}`}>email</a> me.
      </p>
    </section>

    <footer
      class:list={[revealClass, 'mt-8 sm:mt-12']}
      style="--reveal-delay: 360ms"
    >
      <p class="text-muted-foreground text-sm leading-relaxed">
        lesterong.com / 2019–{new Date().getFullYear()} / design engineer
      </p>
    </footer>
  </main>

  <script is:inline>
    const orb = document.querySelector('[data-scroll-orb]');
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const links = document.querySelectorAll('a');
    const workList = document.querySelector('[data-work-list]');
    const workMask = document.querySelector('[data-work-mask]');
    const workToggle = document.querySelector('[data-work-toggle]');
    const extraWorkRows = document.querySelectorAll('[data-work-extra]');
    const projectHoverTriggers = document.querySelectorAll(
      '[data-project-hover-trigger]',
    );

    const LINK_UNDERLINE_VARIANTS = 4;
    const PROJECT_PREVIEW_OFFSET = 20;
    const PROJECT_PREVIEW_SIZE = 96;
    const WORK_TRANSITION_MS = 300;
    let workTransitionTimeout;
    let workTransitionFrame;
    let workAnimation;

    links.forEach((link) => {
      const variant = Math.floor(Math.random() * LINK_UNDERLINE_VARIANTS) + 1;
      link.style.setProperty(
        '--link-underline',
        `var(--link-underline-${variant})`,
      );
    });

    const setExtraRowsHidden = (isHidden) => {
      extraWorkRows.forEach((row) => {
        row.hidden = isHidden;
        row.style.display = isHidden ? 'none' : '';
      });
    };

    const syncWorkToggle = (isExpanded) => {
      if (!workToggle) return;

      workToggle.setAttribute('aria-expanded', String(isExpanded));
      workToggle.textContent = isExpanded
        ? workToggle.dataset.expandedLabel
        : workToggle.dataset.collapsedLabel;
    };

    const getCollapsedWorkHeight = () => {
      setExtraRowsHidden(true);
      const height = workMask.scrollHeight;
      setExtraRowsHidden(false);
      return height;
    };

    const setWorkExpanded = (isExpanded) => {
      syncWorkToggle(isExpanded);

      if (!workMask || reducedMotion.matches) {
        setExtraRowsHidden(!isExpanded);
        workMask?.classList.toggle('work-table-mask', !isExpanded);

        if (workList) {
          workList.classList.toggle('pb-14', !isExpanded);
          workList.style.paddingBottom = isExpanded ? '3.5rem' : '';
        }

        return;
      }

      window.clearTimeout(workTransitionTimeout);
      window.cancelAnimationFrame(workTransitionFrame);
      workAnimation?.cancel();
      workAnimation = undefined;
      workToggle?.setAttribute('disabled', '');

      const startHeight = workMask.offsetHeight;

      if (isExpanded) {
        setExtraRowsHidden(false);
      }

      const endHeight = isExpanded
        ? workMask.scrollHeight
        : getCollapsedWorkHeight();

      workMask.style.height = `${startHeight}px`;
      workMask.getBoundingClientRect();

      if (isExpanded) {
        workMask.classList.remove('work-table-mask');
      } else {
        workMask.classList.add('work-table-mask');
      }

      if (workList) {
        workList.classList.toggle('pb-14', !isExpanded);
        workList.style.paddingBottom = isExpanded ? '3.5rem' : '';
      }

      const finishTransition = () => {
        if (!workToggle?.hasAttribute('disabled')) return;

        window.clearTimeout(workTransitionTimeout);

        if (!isExpanded) {
          setExtraRowsHidden(true);
        }

        window.cancelAnimationFrame(workTransitionFrame);
        workAnimation = undefined;
        workMask.classList.toggle('work-table-mask', !isExpanded);
        workMask.style.height = '';
        workToggle?.removeAttribute('disabled');
        workMask.removeEventListener('transitionend', handleTransitionEnd);
      };

      const handleTransitionEnd = (event) => {
        if (event.propertyName !== 'height') return;
        window.clearTimeout(workTransitionTimeout);
        finishTransition();
      };

      if (workMask.animate) {
        workAnimation = workMask.animate(
          [{ height: `${startHeight}px` }, { height: `${endHeight}px` }],
          {
            duration: WORK_TRANSITION_MS,
            easing: 'ease-out',
          },
        );
        workMask.style.height = `${endHeight}px`;
        workAnimation.addEventListener('finish', finishTransition, {
          once: true,
        });
        workTransitionTimeout = window.setTimeout(
          finishTransition,
          WORK_TRANSITION_MS + 50,
        );
        return;
      }

      workMask.addEventListener('transitionend', handleTransitionEnd);

      workTransitionFrame = window.requestAnimationFrame(() => {
        workTransitionFrame = window.requestAnimationFrame(() => {
          workMask.style.height = `${endHeight}px`;
        });
      });

      workTransitionTimeout = window.setTimeout(
        finishTransition,
        WORK_TRANSITION_MS + 50,
      );
    };

    if (workToggle && extraWorkRows.length > 0) {
      workToggle.addEventListener('click', () => {
        const isExpanded = workToggle.getAttribute('aria-expanded') === 'true';
        setWorkExpanded(!isExpanded);
      });
    }

    if (!reducedMotion.matches) {
      projectHoverTriggers.forEach((trigger) => {
        const row = trigger.closest('tr');
        const preview = row?.querySelector('[data-project-hover-preview]');
        const previewInner = row?.querySelector(
          '[data-project-hover-preview-inner]',
        );
        let hideTimeout;

        if (!preview || !previewInner) return;

        document.body.append(preview);

        const movePreview = (event) => {
          const viewportPadding = 16;
          const hasRoomOnRight =
            event.clientX + PROJECT_PREVIEW_OFFSET + PROJECT_PREVIEW_SIZE <
            window.innerWidth - viewportPadding;
          const x = hasRoomOnRight
            ? event.clientX + PROJECT_PREVIEW_OFFSET
            : event.clientX - PROJECT_PREVIEW_OFFSET - PROJECT_PREVIEW_SIZE;
          const y = Math.min(
            Math.max(event.clientY, viewportPadding + PROJECT_PREVIEW_SIZE / 2),
            window.innerHeight - viewportPadding - PROJECT_PREVIEW_SIZE / 2,
          );

          preview.style.transform = `translate3d(${x}px, ${y}px, 0)`;
        };

        trigger.addEventListener('pointerenter', (event) => {
          window.clearTimeout(hideTimeout);
          movePreview(event);
          preview.classList.remove('hidden');
          window.requestAnimationFrame(() => {
            previewInner.style.opacity = '1';
            previewInner.style.scale = '1';
          });
        });

        trigger.addEventListener('pointermove', movePreview);

        trigger.addEventListener('pointerleave', () => {
          previewInner.style.opacity = '0';
          previewInner.style.scale = '0.9';
          hideTimeout = window.setTimeout(() => {
            preview.classList.add('hidden');
          }, 150);
        });
      });
    }

    if (orb && !reducedMotion.matches) {
      let ticking = false;

      const updateOrb = () => {
        const progress = window.scrollY;
        const y = progress * 0.08;
        const x = Math.sin(progress * 0.002) * 18;

        orb.style.transform = `translate3d(${x}px, ${y}px, 0)`;
        ticking = false;
      };

      const requestUpdate = () => {
        if (!ticking) {
          window.requestAnimationFrame(updateOrb);
          ticking = true;
        }
      };

      updateOrb();
      window.addEventListener('scroll', requestUpdate, { passive: true });
    }
  </script>
</Layout>
