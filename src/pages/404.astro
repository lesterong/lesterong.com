---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page not found"
  description="The page you were looking for could not be found."
>
  <main class="mx-auto max-w-[38rem] px-4 py-16 sm:px-6 sm:py-10">
    <header class="mb-16 sm:mb-12">
      <h1 class="text-base font-semibold tracking-tight">Page not found.</h1>
      <p class="text-muted-foreground mt-1 leading-relaxed">
        This link doesn’t point anywhere on the site right now.
      </p>
    </header>

    <section class="my-8">
      <p class="text-muted-foreground leading-relaxed">
        <a href="/">Back to lesterong.com</a>
      </p>
    </section>
  </main>
</Layout>
